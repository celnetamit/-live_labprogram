# ---- Required ----
# NextAuth session encryption secret. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
# Public URL of the deployment (must match the domain Coolify serves).
NEXTAUTH_URL="https://labs.example.com"
# PostgreSQL connection string (use your Coolify Postgres service's internal URL).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# ---- Optional ----
# Razorpay live payments. Leave blank to use the built-in mock checkout.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
# Source API for `npm run import:labs` re-sync. If unreachable, the committed
# prisma/labs-snapshot.json is used automatically.
LAB_SOURCE_URL=""
