generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  organization  String?
  designation   String?
  role          String    @default("USER")
  status        String    @default("ACTIVE")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  labAccess     LabAccess[]
  ownedLabs     Lab[]     @relation("LabOwner")
  accessRequests AccessRequest[]
  orders        Order[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Lab {
  id          String   @id @default(cuid())
  slug        String?  @unique
  name        String
  description String?
  synopsis    String?
  subject     String?
  difficulty  String?  // Beginner, Intermediate, Advanced
  points      Int      @default(0)
  instructions String?
  starterCode String?
  sourceUrl   String?  // live lab launch URL
  tags        String?  // JSON string array
  keySkills   String?  // JSON string array
  priceMinor  Int      @default(49900)
  currency    String   @default("INR")
  enabled     Boolean  @default(true)
  domainUrl   String   @unique
  category    String?
  thumbnail   String?
  accessType  String   @default("PRIVATE") // PUBLIC, PRIVATE, SUBSCRIPTION
  status      String   @default("ACTIVE") // ACTIVE, ARCHIVED, INACTIVE
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerId     String?
  owner       User?    @relation("LabOwner", fields: [ownerId], references: [id])

  accesses    LabAccess[]
  accessRequests AccessRequest[]
  orderItems  OrderItem[]
}

model LabAccess {
  id        String   @id @default(cuid())
  userId    String
  labId     String
  grantedAt DateTime @default(now())
  expiresAt DateTime?
  grantedBy String?  // Admin ID who granted
  source    String   @default("ADMIN") // ADMIN | PURCHASE
  orderId   String?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lab       Lab      @relation(fields: [labId], references: [id], onDelete: Cascade)

  @@unique([userId, labId])
}

model Order {
  id               String   @id @default(cuid())
  userId           String
  status           String   @default("PENDING") // PENDING | PAID | FAILED
  amountMinor      Int
  currency         String   @default("INR")
  provider         String   @default("mock") // razorpay | mock
  providerOrderId  String?
  providerPaymentId String?
  createdAt        DateTime @default(now())
  paidAt           DateTime?

  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items            OrderItem[]
}

model OrderItem {
  id         String @id @default(cuid())
  orderId    String
  labId      String
  labSlug    String
  labTitle   String
  priceMinor Int

  order      Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  lab        Lab    @relation(fields: [labId], references: [id], onDelete: Cascade)
}

model AccessRequest {
  id          String   @id @default(cuid())
  userId      String
  labId       String
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  requestedAt DateTime @default(now())
  reviewedAt  DateTime?
  reviewedBy  String?
  notes       String?

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lab         Lab      @relation(fields: [labId], references: [id], onDelete: Cascade)
}
